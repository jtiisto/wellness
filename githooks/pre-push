#!/usr/bin/env bash
# Pre-push hook — scale the checks to what's actually being pushed.
#
#   * code/other changes  -> full pytest + coverage (--cov-fail-under=88) + JS
#                            node:test suite   (the default; unchanged)
#   * docs-only push      -> run ONLY the fast structural guard
#     (every changed file   (test/test_deploy_manifest.py); skip pytest/cov/e2e/JS
#      is *.md or docs/**)   — nothing in the heavy suite depends on doc contents,
#                            and the guard still catches a stray new top-level file
#   * no-op push          -> skip everything (empty net diff vs the remote, e.g. a
#     (no file changes)      no-change fast-forward or merge — nothing to test)
#
# "Net change" is the endpoint diff remote_sha..local_sha, so a merge whose result
# matches the remote is a no-op. New branches diff against the origin/main
# merge-base. Branch deletions are skipped. When a safe baseline can't be
# determined, it falls back to the FULL suite.
#
# Overrides:
#   WELLNESS_FULL_PUSH=1   force the full suite regardless of the diff
#   PREPUSH_DRYRUN=1       print the decision + changed files, run nothing
#
# Tracked in githooks/ and activated per-clone with
#   git config core.hooksPath githooks
set -uo pipefail

ZERO="0000000000000000000000000000000000000000"
BASELINE_REF="origin/main"

decision="full"
reason="code/other changes present"
changed=""
saw_update=0

classify() {
    while read -r local_ref local_sha remote_ref remote_sha; do
        [[ -z "${local_ref:-}" ]] && continue
        local_sha="${local_sha:-$ZERO}"
        remote_sha="${remote_sha:-$ZERO}"
        [[ "$local_sha" == "$ZERO" ]] && continue   # branch deletion — nothing to test
        saw_update=1

        local base
        if [[ "$remote_sha" == "$ZERO" ]]; then
            # New branch on the remote: compare against the integration baseline.
            if git rev-parse --verify --quiet "$BASELINE_REF" >/dev/null; then
                base="$(git merge-base "$BASELINE_REF" "$local_sha" 2>/dev/null || true)"
                [[ -n "$base" ]] || { decision="full"; reason="new branch with no merge-base vs $BASELINE_REF"; return; }
            else
                decision="full"; reason="new branch and $BASELINE_REF not present locally"; return
            fi
        else
            base="$remote_sha"
        fi

        local files
        files="$(git diff --name-only "$base" "$local_sha" 2>/dev/null)" \
            || { decision="full"; reason="could not diff $base..$local_sha"; return; }
        changed+="$files"$'\n'
    done

    changed="$(printf '%s' "$changed" | sed '/^$/d')"
    if [[ "$saw_update" == "0" ]]; then decision="skip"; reason="no content updates (deletions only)"; return; fi
    if [[ -z "$changed" ]]; then decision="skip"; reason="no-op: empty net diff vs the remote"; return; fi

    local non_docs
    non_docs="$(printf '%s\n' "$changed" | grep -vE '(\.md$|^docs/)' || true)"
    if [[ -z "$non_docs" ]]; then decision="docs"; reason="docs-only (*.md / docs/**)"; return; fi

    decision="full"; reason="code/other changes present"
}

if [[ "${WELLNESS_FULL_PUSH:-}" == "1" ]]; then
    decision="full"; reason="WELLNESS_FULL_PUSH=1 override"
else
    classify
fi

echo "pre-push: ${decision} — ${reason}"
if [[ -n "$changed" ]]; then
    echo "pre-push: changed files:"
    printf '%s\n' "$changed" | sed 's/^/  /'
fi

if [[ "${PREPUSH_DRYRUN:-}" == "1" ]]; then
    echo "pre-push: DRYRUN — running nothing."
    exit 0
fi

case "$decision" in
    skip)
        echo "Nothing to test for this push. Proceeding."
        ;;
    docs)
        echo "Docs-only push — running the fast structural guard (skipping full suite/coverage/e2e/JS)..."
        python3 -m pytest test/test_deploy_manifest.py -q 2>&1 || exit $?
        echo "Structural guard passed. Pushing."
        ;;
    full)
        echo "Running full test suite with coverage before push..."
        python3 -m pytest --cov=src --cov=mcp_servers --cov-report=term-missing --cov-fail-under=88 2>&1 || exit $?
        echo "Running JS unit tests (node:test)..."
        node --test test/js/*.test.js || exit $?
        echo "All tests passed with sufficient coverage. Pushing..."
        ;;
esac
exit 0
